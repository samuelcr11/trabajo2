# Ejemplo de variables de entorno para el backend
# Copia este archivo a backend/.env y rellena los valores reales.

DJANGO_SECRET_KEY=tu_clave_segura
DJANGO_DEBUG=1
FIREBASE_API_KEY=tu_firebase_api_key
FIREBASE_PROJECT_ID=tu_project_id
FIREBASE_CREDENTIALS=/ruta/a/tu/serviceAccountKey.json
# Alternativa para Vercel: env var JSON con el contenido completo del archivo de credenciales
# FIREBASE_CREDENTIALS_JSON={...json...}

# PostgreSQL / Neon
# DATABASE_URL=postgresql://user:password@host:port/dbname?sslmode=require
